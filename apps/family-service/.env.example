# NestJS family-service
PORT=4000
NODE_ENV=development

# Database (PostgreSQL via TypeORM)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=family_os
DB_USER=family_user
DB_PASSWORD=change_me

# Redis
CACHE_HOST=localhost
CACHE_PORT=6379

# MQTT
BROKER_URL=mqtt://localhost:1883

# JWT
JWT_SECRET=change_me_generate_a_strong_secret
JWT_REFRESH_SECRET=change_me_generate_a_strong_refresh_secret

# LLM
LLM_API_KEY=your_api_key
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# SSO (OAuth2/OIDC)
SSO_ENABLED=false
SSO_PROVIDER=keycloak
SSO_ISSUER_URL=https://sso.example.com/realms/family-os
SSO_CLIENT_ID=family-os
SSO_CLIENT_SECRET=change_me
SSO_REDIRECT_URI=http://localhost:4000/api/v1/auth/sso/callback
SSO_SCOPES=openid profile email

# Spring Boot internal API
SPRING_API_BASE_URL=http://localhost:8080/api/v1
