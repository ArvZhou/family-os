# =============================================================================
# Family OS — Environment Variables Template
# Copy to .env and fill in real values.
# NEVER commit .env or real secrets to version control.
# =============================================================================

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=family_os
DB_USER=family_user
DB_PASSWORD=change_me

# --- Cache (Redis) ---
CACHE_HOST=localhost
CACHE_PORT=6379

# --- Message Broker (MQTT) ---
BROKER_URL=mqtt://localhost:1883
BROKER_WS_URL=ws://localhost:8083

# --- Object Storage (MinIO) ---
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# --- Authentication (JWT) ---
JWT_SECRET=change_me_generate_a_strong_secret
JWT_REFRESH_SECRET=change_me_generate_a_strong_refresh_secret
JWT_EXPIRATION=1800
JWT_REFRESH_EXPIRATION=604800

# --- AI / LLM ---
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_MS=30000

# --- SSO (OAuth2 / OIDC) — Reserved ---
SSO_ENABLED=false
SSO_PROVIDER=keycloak
SSO_ISSUER_URL=https://sso.example.com/realms/family-os
SSO_CLIENT_ID=family-os
SSO_CLIENT_SECRET=change_me
SSO_REDIRECT_URI=http://localhost:4000/api/v1/auth/sso/callback
SSO_SCOPES=openid profile email
